<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.BarChart?>
<?import javafx.scene.chart.CategoryAxis?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.chart.PieChart?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>

<BorderPane prefHeight="900.0" prefWidth="1440.0"
            xmlns="http://javafx.com/javafx/21.0.6"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.example.fugitivefinder.view.LeaderboardController"
            stylesheets="@styles/charts.css, @styles/buttons.css"
            style="-fx-background-color: #081120;">

    <!-- LEFT SIDEBAR -->
    <left>
        <VBox prefWidth="220.0" spacing="12.0"
              style="-fx-background-color: #0f172a; -fx-padding: 20;">
            <children>
                <HBox spacing="10.0" alignment="CENTER_LEFT">
                    <children>
                        <ImageView fitHeight="48.0" fitWidth="48.0" preserveRatio="true">
                            <image><Image url="@images/logo.png" /></image>
                        </ImageView>
                        <Label text="Fugitive Finder" textFill="WHITE" wrapText="true">
                            <font><Font size="16.0" /></font>
                        </Label>
                    </children>
                </HBox>

                <Region prefHeight="10.0" />

                <Label text="Dashboard" onMouseClicked="#goToDashboard"
                       style="-fx-text-fill: #cbd5e1; -fx-padding: 12 16; -fx-cursor: hand;" />
                <Label text="Maps" onMouseClicked="#goToMap"
                       style="-fx-text-fill: #cbd5e1; -fx-padding: 12 16; -fx-cursor: hand;" />
                <Label text="Analytics" onMouseClicked="#goToAnalytics"
                       style="-fx-text-fill: #cbd5e1; -fx-padding: 12 16; -fx-cursor: hand;" />
                <Label text="Leaderboard"
                       style="-fx-background-color: #1e293b; -fx-text-fill: white; -fx-padding: 12 16; -fx-background-radius: 10; -fx-font-weight: bold;" />
                <Label text="Profile" onMouseClicked="#goToUserProfile"
                       style="-fx-text-fill: #cbd5e1; -fx-padding: 12 16; -fx-cursor: hand;" />
            </children>
        </VBox>
    </left>

    <!-- TOP HEADER -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="14.0" prefHeight="90.0" minHeight="90.0" maxHeight="90.0"
              style="-fx-background-color: #0b1320; -fx-padding: 18 24;">
            <children>
                <Label text="Most Dangerous &amp; Region Stats" textFill="WHITE">
                    <font><Font size="28.0" /></font>
                </Label>
                <Region HBox.hgrow="ALWAYS" />

                <!-- Stats Cards -->
                <VBox alignment="CENTER" spacing="2.0"
                      style="-fx-background-color: #111827; -fx-background-radius: 10; -fx-padding: 8 16;">
                    <Label text="Highest Reward" textFill="#94a3b8"><font><Font size="10.0" /></font></Label>
                    <Label fx:id="highestRewardLabel" text="--" textFill="#ef4444">
                        <font><Font size="14.0" /></font>
                    </Label>
                </VBox>

                <Region HBox.hgrow="ALWAYS" />

                <VBox alignment="CENTER" spacing="2.0"
                      style="-fx-background-color: #111827; -fx-background-radius: 10; -fx-padding: 8 16;">
                    <Label text="Hottest Region" textFill="#94a3b8"><font><Font size="10.0" /></font></Label>
                    <Label fx:id="mostDangerousRegionLabel" text="--" textFill="#f59e0b">
                        <font><Font size="14.0" /></font>
                    </Label>
                </VBox>
                <VBox alignment="CENTER" spacing="2.0"
                      style="-fx-background-color: #111827; -fx-background-radius: 10; -fx-padding: 8 16;">
                    <Label text="Analyzed" textFill="#94a3b8"><font><Font size="10.0" /></font></Label>
                    <Label fx:id="totalAnalyzedLabel" text="--" textFill="#4fd1c5">
                        <font><Font size="14.0" /></font>
                    </Label>
                </VBox>
                <VBox alignment="CENTER" spacing="2.0"
                      style="-fx-background-color: #111827; -fx-background-radius: 10; -fx-padding: 8 16;">
                    <Label text="Critical" textFill="#94a3b8"><font><Font size="10.0" /></font></Label>
                    <Label fx:id="criticalCountLabel" text="--" textFill="#ef4444">
                        <font><Font size="14.0" /></font>
                    </Label>
                </VBox>
            </children>
        </HBox>
    </top>

    <!-- CENTER -->
    <center>
        <StackPane>
            <!-- Loading Overlay -->
            <VBox fx:id="loadingOverlay" alignment="CENTER" spacing="20.0"
                  style="-fx-background-color: rgba(8,17,32,0.95);">
                <ProgressIndicator fx:id="loadingSpinner" prefWidth="80.0" prefHeight="80.0"
                                   style="-fx-progress-color: #ef4444;" />
                <Label fx:id="statusLabel" text="Loading..." textFill="#cbd5e1">
                    <font><Font size="18.0" /></font>
                </Label>
            </VBox>

            <!-- Content -->
            <VBox fx:id="contentContainer" spacing="16.0" style="-fx-padding: 16;">
                <!-- Leaderboard Table -->
                <VBox style="-fx-background-color: #111827; -fx-background-radius: 14; -fx-padding: 12;"
                      VBox.vgrow="ALWAYS" maxHeight="380">
                    <Label text="⚠ Most Dangerous Fugitives" textFill="#f59e0b"
                           style="-fx-font-weight: bold; -fx-padding: 0 0 5 0;">
                        <font><Font size="16.0" /></font>
                    </Label>
                    <TableView fx:id="leaderboardTable" VBox.vgrow="ALWAYS"
                               style="-fx-background-color: #111827; -fx-control-inner-background: #1e293b; -fx-text-fill: white;">
                        <columns>
                            <TableColumn fx:id="rankColumn" text="#" prefWidth="50" />
                            <TableColumn fx:id="nameColumn" text="Name" prefWidth="280" />
                            <TableColumn fx:id="rewardColumn" text="Reward" prefWidth="250" />
                            <TableColumn fx:id="dangerColumn" text="Threat Level" prefWidth="130" />
                            <TableColumn fx:id="officeColumn" text="Field Office" prefWidth="150" />
                        </columns>
                    </TableView>
                </VBox>

                <!-- Region Charts Row -->
                <HBox spacing="16.0" VBox.vgrow="ALWAYS">
                    <!-- Cases by Region -->
                    <VBox HBox.hgrow="ALWAYS"
                          style="-fx-background-color: #111827; -fx-background-radius: 14; -fx-padding: 12;">
                        <BarChart fx:id="regionCasesChart" VBox.vgrow="ALWAYS"
                                  style="-fx-background-color: transparent;">
                            <xAxis><CategoryAxis tickLabelFill="#cbd5e1" /></xAxis>
                            <yAxis><NumberAxis tickLabelFill="#cbd5e1" /></yAxis>
                        </BarChart>
                    </VBox>

                    <!-- Regional Distribution Pie -->
                    <VBox HBox.hgrow="ALWAYS"
                          style="-fx-background-color: #111827; -fx-background-radius: 14; -fx-padding: 12;">
                        <PieChart fx:id="regionPieChart" VBox.vgrow="ALWAYS"
                                  style="-fx-background-color: transparent;" legendSide="BOTTOM" />
                    </VBox>

                    <!-- Avg Reward by Region -->
                    <VBox HBox.hgrow="ALWAYS"
                          style="-fx-background-color: #111827; -fx-background-radius: 14; -fx-padding: 12;">
                        <BarChart fx:id="regionRewardChart" VBox.vgrow="ALWAYS"
                                  style="-fx-background-color: transparent;">
                            <xAxis><CategoryAxis tickLabelFill="#cbd5e1" /></xAxis>
                            <yAxis><NumberAxis tickLabelFill="#cbd5e1" /></yAxis>
                        </BarChart>
                    </VBox>
                </HBox>
            </VBox>
        </StackPane>
    </center>
</BorderPane>
