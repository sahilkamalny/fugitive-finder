<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.Cursor?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>
<?import javafx.scene.control.Label?>

<StackPane prefHeight="900.0" prefWidth="1440.0"
           style="-fx-background-color: #081120;"
           stylesheets="@styles/buttons.css"
           xmlns="http://javafx.com/javafx/23.0.1"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="org.example.fugitivefinder.view.CreateAccountPageController">

    <children>
        <VBox alignment="CENTER" spacing="15.0" maxWidth="500.0" maxHeight="720.0"
              style="-fx-background-color: #0f172a; -fx-background-radius: 30; -fx-border-color: #334155; -fx-border-radius: 30; -fx-border-width: 1.5; -fx-padding: 40;">
            <children>
                <VBox alignment="CENTER" spacing="10.0">
                    <Label text="Create Account" textFill="WHITE">
                        <font><Font size="30.0" /></font>
                    </Label>
                    <Region prefHeight="10.0" />
                </VBox>

                <VBox spacing="5.0">
                    <Label text="First Name" textFill="WHITE">
                        <font><Font size="15.0" /></font>
                    </Label>
                    <TextField fx:id="firstNameField" prefHeight="42.0" style="-fx-background-radius: 10;" />
                </VBox>

                <VBox spacing="5.0">
                    <Label text="Last Name" textFill="WHITE">
                        <font><Font size="15.0" /></font>
                    </Label>
                    <TextField fx:id="lastNameField" prefHeight="42.0" style="-fx-background-radius: 10;" />
                </VBox>

                <VBox spacing="5.0">
                    <Label text="Username" textFill="WHITE">
                        <font><Font size="15.0" /></font>
                    </Label>
                    <TextField fx:id="usernameField" prefHeight="42.0" style="-fx-background-radius: 10;" />
                </VBox>

                <VBox spacing="5.0">
                    <Label text="Email" textFill="WHITE">
                        <font><Font size="15.0" /></font>
                    </Label>
                    <TextField fx:id="emailField" prefHeight="42.0" style="-fx-background-radius: 10;" />
                </VBox>

                <VBox spacing="5.0">
                    <Label text="Password" textFill="WHITE">
                        <font><Font size="15.0" /></font>
                    </Label>
                    <PasswordField fx:id="passwordField" prefHeight="42.0" style="-fx-background-radius: 10;" />
                </VBox>

                <VBox spacing="5.0">
                    <Label text="Confirm Password" textFill="WHITE">
                        <font><Font size="15.0" /></font>
                    </Label>
                    <PasswordField fx:id="confirmPasswordField" prefHeight="42.0" style="-fx-background-radius: 10;" />
                </VBox>

                <Region prefHeight="15.0" VBox.vgrow="ALWAYS" />

                <Button mnemonicParsing="false" onAction="#handleCreateAccount" prefHeight="50.0" prefWidth="420.0"
                        styleClass="button-orange"
                        text="Create Account">
                    <cursor><Cursor fx:constant="HAND" /></cursor>
                </Button>

                <Region prefHeight="5.0" />

                <VBox alignment="CENTER">
                    <Text fill="#fbbf24" onMouseClicked="#returnToLogin" strokeType="OUTSIDE" strokeWidth="0.0" text="Return to Login">
                        <font><Font size="16.0" /></font>
                        <cursor><Cursor fx:constant="HAND" /></cursor>
                    </Text>
                </VBox>
            </children>
        </VBox>
    </children>
</StackPane>