<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.Cursor?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.shape.Rectangle?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<AnchorPane prefHeight="900.0" prefWidth="1440.0"
            xmlns="http://javafx.com/javafx/23.0.1"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.example.fugitivefinder.view.CreateAccountPageController">

    <children>
        <Pane prefHeight="900.0" prefWidth="1440.0">
            <children>
                <Rectangle fill="#081120" height="900.0" width="1440.0" />

                <Rectangle arcHeight="30.0" arcWidth="30.0" fill="#0f172a" height="690.0" layoutX="470.0" layoutY="100.0" stroke="#334155" strokeWidth="1.5" width="500.0" />

                <Text fill="WHITE" layoutX="615.0" layoutY="165.0" strokeType="OUTSIDE" strokeWidth="0.0" text="Create Account">
                    <font>
                        <Font size="30.0" />
                    </font>
                </Text>

                <Text fill="WHITE" layoutX="555.0" layoutY="235.0" strokeType="OUTSIDE" strokeWidth="0.0" text="First Name">
                    <font>
                        <Font size="15.0" />
                    </font>
                </Text>
                <TextField fx:id="firstNameField" layoutX="550.0" layoutY="248.0" prefHeight="42.0" prefWidth="340.0"
                           style="-fx-background-radius: 10;" />

                <Text fill="WHITE" layoutX="555.0" layoutY="315.0" strokeType="OUTSIDE" strokeWidth="0.0" text="Last Name">
                    <font>
                        <Font size="15.0" />
                    </font>
                </Text>
                <TextField fx:id="lastNameField" layoutX="550.0" layoutY="328.0" prefHeight="42.0" prefWidth="340.0"
                           style="-fx-background-radius: 10;" />

                <Text fill="WHITE" layoutX="555.0" layoutY="395.0" strokeType="OUTSIDE" strokeWidth="0.0" text="Username">
                    <font>
                        <Font size="15.0" />
                    </font>
                </Text>
                <TextField fx:id="usernameField" layoutX="550.0" layoutY="408.0" prefHeight="42.0" prefWidth="340.0"
                           style="-fx-background-radius: 10;" />

                <Text fill="WHITE" layoutX="555.0" layoutY="475.0" strokeType="OUTSIDE" strokeWidth="0.0" text="Email">
                    <font>
                        <Font size="15.0" />
                    </font>
                </Text>
                <TextField fx:id="emailField" layoutX="550.0" layoutY="488.0" prefHeight="42.0" prefWidth="340.0"
                           style="-fx-background-radius: 10;" />

                <Text fill="WHITE" layoutX="555.0" layoutY="555.0" strokeType="OUTSIDE" strokeWidth="0.0" text="Password">
                    <font>
                        <Font size="15.0" />
                    </font>
                </Text>
                <PasswordField fx:id="passwordField" layoutX="550.0" layoutY="568.0" prefHeight="42.0" prefWidth="340.0"
                               style="-fx-background-radius: 10;" />

                <Text fill="WHITE" layoutX="555.0" layoutY="635.0" strokeType="OUTSIDE" strokeWidth="0.0" text="Confirm Password">
                    <font>
                        <Font size="15.0" />
                    </font>
                </Text>
                <PasswordField fx:id="confirmPasswordField" layoutX="550.0" layoutY="648.0" prefHeight="42.0" prefWidth="340.0"
                               style="-fx-background-radius: 10;" />

                <Button layoutX="550.0" layoutY="720.0" mnemonicParsing="false" onAction="#handleCreateAccount"
                        prefHeight="50.0" prefWidth="340.0"
                        style="-fx-background-color: #f59e0b; -fx-text-fill: #111827; -fx-font-size: 18px; -fx-font-weight: bold; -fx-background-radius: 10;"
                        text="Create Account">
                    <cursor>
                        <Cursor fx:constant="HAND" />
                    </cursor>
                </Button>

                <Text fill="#fbbf24" layoutX="655.0" layoutY="805.0" onMouseClicked="#returnToLogin"
                      strokeType="OUTSIDE" strokeWidth="0.0" text="Return to Login">
                    <font>
                        <Font size="16.0" />
                    </font>
                    <cursor>
                        <Cursor fx:constant="HAND" />
                    </cursor>
                </Text>
            </children>
        </Pane>
    </children>
</AnchorPane>