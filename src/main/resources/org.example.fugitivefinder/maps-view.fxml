<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<?import javafx.scene.control.ProgressIndicator?>
<BorderPane prefHeight="900.0" prefWidth="1440.0" style="-fx-background-color: #081120;" stylesheets="@styles/buttons.css" xmlns="http://javafx.com/javafx/16" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.fugitivefinder.view.MapsViewController">

    <left>
        <VBox prefWidth="220.0" spacing="12.0"
              style="-fx-background-color: #0f172a; -fx-padding: 20;">
            <children>
                <HBox spacing="10.0" alignment="CENTER_LEFT">
                    <children>
                        <ImageView fitHeight="48.0" fitWidth="48.0" preserveRatio="true">
                            <image><Image url="@images/logo.png" /></image>
                        </ImageView>
                        <Label text="Fugitive Finder" textFill="WHITE" wrapText="true">
                            <font><Font size="16.0" /></font>
                        </Label>
                    </children>
                </HBox>

                <Region prefHeight="10.0" />

                <Label text="Dashboard" onMouseClicked="#goToDashboard"
                       style="-fx-text-fill: white; -fx-padding: 12 16; -fx-cursor: hand;" />
                <Label text="Maps"
                       style="-fx-background-color: #1e293b; -fx-text-fill: white; -fx-padding: 12 16; -fx-background-radius: 10; -fx-font-weight: bold;" />
                <Label text="Analytics" onMouseClicked="#goToCharts"
                       style="-fx-text-fill: white; -fx-padding: 12 16; -fx-cursor: hand;" />
                <Label text="Leaderboard" onMouseClicked="#goToLeaderboard"
                       style="-fx-text-fill: white; -fx-padding: 12 16; -fx-cursor: hand;" />
                <Label text="Profile" onMouseClicked="#goToUserProfile"
                       style="-fx-text-fill: white; -fx-padding: 12 16; -fx-cursor: hand;" />

                <Region VBox.vgrow="ALWAYS" />
                <Label text="Sign Out" onMouseClicked="#signOut"
                       style="-fx-text-fill: #ef4444; -fx-padding: 12 16; -fx-cursor: hand;" />
            </children>
        </VBox>
    </left>

    <top>
        <HBox alignment="CENTER_LEFT" spacing="14.0" prefHeight="90.0" minHeight="90.0" maxHeight="90.0" style="-fx-background-color: #0b1320; -fx-padding: 18 24;">
            <children>
                <VBox spacing="5">
                    <Label style="-fx-font-size: 30;" text="Maps" textFill="white" />
                </VBox>
                <Region HBox.hgrow="ALWAYS" />
                <Label fx:id="usernameLabel" style="-fx-font-size: 16;" text="DetectiveUser" textFill="white" />
                <ImageView fitHeight="44.0" fitWidth="44.0" preserveRatio="true">
                    <Image url="@images/detective-avatar.png" />
                </ImageView>
            </children>
        </HBox>
    </top>

    <center>
        <VBox spacing="20.0" style="-fx-padding: 24;">
            <children>
                <HBox alignment="CENTER_LEFT">
                    <children>
                        <VBox spacing="5">
                            <Label style="-fx-font-size: 24;" text="FBI Field Office Map" textFill="white" />
                            <Label style="-fx-text-fill: white;" text="Select a marker to view local fugitives" />
                        </VBox>
                        <Region HBox.hgrow="ALWAYS" />
                        <Button onAction="#toggleHeatMap" style="-fx-background-color: #ef4444; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 10 20;" text="Toggle Heatmap">
                            <cursor><Cursor fx:constant="HAND" /></cursor>
                        </Button>
                    </children>
                </HBox>

                <HBox alignment="CENTER_LEFT" spacing="12.0">
                    <TextField fx:id="nameSearchField"
                               promptText="Find by name"
                               prefWidth="250.0"
                               onAction="#handleNameSearch"
                               style="-fx-background-radius: 10;" />

                    <Button text="Search"
                            onAction="#handleNameSearch"
                            style="-fx-background-color: #ffa500; -fx-text-fill: black; -fx-font-weight: bold; -fx-background-radius: 8;" />

                    <Button text="Clear"
                            onAction="#clearNameSearch"
                            style="-fx-background-color: #334155; -fx-text-fill: white; -fx-background-radius: 8;" />
                    <children>
                        <Label text="Filter by Office:" textFill="white" />

                        <ComboBox fx:id="officeFilterComboBox"
                                  prefWidth="220.0"
                                  onAction="#handleOfficeFilter"
                                  style="-fx-background-color: #1e293b; -fx-text-fill: white;" />

                        <Button text="Clear Filter"
                                onAction="#clearOfficeFilter"
                                style="-fx-background-color: #334155; -fx-text-fill: white; -fx-background-radius: 8; -fx-padding: 8 16;" />

                        <Region HBox.hgrow="ALWAYS" />

                
                    </children>
                </HBox>
                <StackPane fx:id="mapContainer" VBox.vgrow="ALWAYS"
                           style="-fx-background-color: #111827; -fx-background-radius: 16; -fx-border-color: #334155; -fx-border-radius: 16; -fx-border-width: 2;">
                    <children>
                        <!-- Loading Overlay -->
                        <VBox fx:id="loadingOverlay" alignment="CENTER" spacing="20.0"
                              style="-fx-background-color: #081120; -fx-background-radius: 14;">
                            <children>
                                <ProgressIndicator fx:id="loadingSpinner"
                                                   prefWidth="80.0" prefHeight="80.0"
                                                   style="-fx-progress-color: #4fd1c5;" />
                                <Label fx:id="statusLabel" text="Loading map data..."
                                       textFill="white">
                                    <font><Font size="18.0" /></font>
                                </Label>
                            </children>
                        </VBox>

                        <VBox alignment="BOTTOM_RIGHT" pickOnBounds="false" spacing="10">
                            <padding>
                                <Insets bottom="30" right="20" />
                            </padding>
                            <children>
                                <Button onAction="#handleResetView" prefHeight="40" prefWidth="80"
                                        style="-fx-background-color: #334155; -fx-text-fill: white; -fx-background-radius: 8;" text="Reset">
                                    <cursor><Cursor fx:constant="HAND" /></cursor>
                                </Button>
                                <Button onAction="#handleZoomIn" prefHeight="40" prefWidth="40"
                                        style="-fx-background-color: #1e293b; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-font-size: 18;" text="+">
                                    <cursor><Cursor fx:constant="HAND" /></cursor>
                                </Button>
                                <Button onAction="#handleZoomOut" prefHeight="40" prefWidth="40"
                                        style="-fx-background-color: #1e293b; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-font-size: 18;" text="-">
                                    <cursor><Cursor fx:constant="HAND" /></cursor>
                                </Button>
                            </children>
                        </VBox>
                    </children>
                    <padding>
                        <Insets bottom="2" left="2" right="2" top="2" />
                    </padding>
                </StackPane>
            </children>
        </VBox>
    </center>
</BorderPane>
