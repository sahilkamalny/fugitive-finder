<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ComboBox?>

<BorderPane prefHeight="900.0" prefWidth="1440.0" style="-fx-background-color: #081120;"
            xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.example.fugitivefinder.view.DashboardController">

    <left>
        <VBox prefWidth="220.0" spacing="18.0" style="-fx-background-color: #0f172a; -fx-padding: 20;">
            <children>
                <HBox spacing="10.0">
                    <children>
                        <ImageView fitHeight="48.0" fitWidth="48.0" preserveRatio="true">
                            <image>
                                <Image url="@images/logo.png"/>
                            </image>
                        </ImageView>
                        <Label text="Fugitive Finder" textFill="WHITE" wrapText="true">
                            <font>
                                <Font size="16.0"/>
                            </font>
                        </Label>
                    </children>
                </HBox>

                <Label style="-fx-background-color: #1e293b; -fx-text-fill: white; -fx-padding: 12 16; -fx-background-radius: 10;"
                       text="Dashboard"/>

                <Label onMouseClicked="#showMapScreen" style="-fx-text-fill: #cbd5e1; -fx-padding: 12 16;"
                       text="Maps">
                    <cursor>
                        <Cursor fx:constant="HAND"/>
                    </cursor>
                </Label>

                <Label onMouseClicked="#showChartsScreen" style="-fx-text-fill: #cbd5e1; -fx-padding: 12 16;"
                       text="Analytics">
                    <cursor>
                        <Cursor fx:constant="HAND"/>
                    </cursor>
                </Label>



                <Label onMouseClicked="#goToUserProfile" style="-fx-text-fill: #cbd5e1; -fx-padding: 12 16;"
                       text="Profile">
                    <cursor>
                        <Cursor fx:constant="HAND"/>
                    </cursor>
                </Label>
            </children>
        </VBox>
    </left>

    <top>
        <HBox alignment="CENTER_LEFT" spacing="14.0" style="-fx-background-color: #0b1320; -fx-padding: 18 24;">
            <children>
                <Label text="Dashboard" textFill="WHITE">
                    <font>
                        <Font size="30.0"/>
                    </font>
                </Label>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="usernameLabel" text="DetectiveUser" textFill="WHITE">
                    <font>
                        <Font size="16.0"/>
                    </font>
                </Label>
                <ImageView fitHeight="44.0" fitWidth="44.0" preserveRatio="true">
                    <image>
                        <Image url="@images/detective-avatar.png"/>
                    </image>
                </ImageView>
            </children>
        </HBox>
    </top>
    <center>
        <ScrollPane fx:id="homeView" fitToWidth="true" hbarPolicy="NEVER"
                    style="-fx-background-color: transparent; -fx-background: transparent;">
            <content>
                <VBox spacing="22.0" style="-fx-padding: 24;">
                    <children>
                        <Label text="Welcome back" textFill="WHITE">
                            <font>
                                <Font size="28.0"/>
                            </font>
                        </Label>

                        <HBox spacing="18.0">
                            <children>
                                <AnchorPane prefHeight="120.0" prefWidth="260.0"
                                            style="-fx-background-color: #1e293b; -fx-background-radius: 16;">
                                    <children>
                                        <Label layoutX="20.0" layoutY="20.0" text="Total Most Wanted"
                                               textFill="#cbd5e1"/>
                                        <Label fx:id="totalWantedLabel" layoutX="20.0" layoutY="55.0" text="0"
                                               textFill="WHITE">
                                            <font>
                                                <Font size="34.0"/>
                                            </font>
                                        </Label>
                                    </children>
                                </AnchorPane>

                                <AnchorPane prefHeight="120.0" prefWidth="260.0"
                                            style="-fx-background-color: #1e293b; -fx-background-radius: 16;">
                                    <children>
                                        <Label layoutX="20.0" layoutY="20.0" text="Reward Cases"
                                               textFill="#cbd5e1"/>
                                        <Label fx:id="rewardCasesLabel" layoutX="20.0" layoutY="55.0" text="0"
                                               textFill="WHITE">
                                            <font>
                                                <Font size="34.0"/>
                                            </font>
                                        </Label>
                                    </children>
                                </AnchorPane>


                            </children>
                        </HBox>

                        <Label text="Featured Targets" textFill="WHITE">
                            <font>
                                <Font size="24.0"/>
                            </font>
                        </Label>

                        <HBox spacing="12.0" alignment="CENTER_LEFT">
                            <children>
                                <Label text="Sort by:" textFill="#cbd5e1"/>

                                <ComboBox fx:id="sortComboBox"
                                          onAction="#handleSort"
                                          prefWidth="180.0"
                                          style="-fx-background-color: #1e293b; -fx-text-fill: white;"/>

                                <Label text="Status:" textFill="#cbd5e1"/>

                                <ComboBox fx:id="statusFilterComboBox"
                                          onAction="#handleFilters"
                                          prefWidth="150.0"
                                          style="-fx-background-color: #1e293b; -fx-text-fill: white;"/>

                                <Label text="Reward:" textFill="#cbd5e1"/>

                                <ComboBox fx:id="rewardFilterComboBox"
                                          onAction="#handleFilters"
                                          prefWidth="170.0"
                                          style="-fx-background-color: #1e293b; -fx-text-fill: white;"/>

                                <Label text="Search:" textFill="#cbd5e1"/>

                                <TextField fx:id="searchField"
                                           onAction="#handleFilters"
                                           promptText="Search name"
                                           prefWidth="200.0"
                                           style="-fx-background-radius: 8;"/>
                            </children>
                        </HBox>
                        <FlowPane fx:id="featuredCardsPane" hgap="18.0" vgap="18.0"
                                  style="-fx-background-color: transparent;"/>

                        <HBox alignment="CENTER" spacing="12.0">
                            <children>
                                <Button fx:id="prevButton" text="Prev" onAction="#goToPrevPage"
                                        style="-fx-background-color: #1e293b; -fx-text-fill: white; -fx-background-radius: 8; -fx-padding: 8 20;"/>
                                <Label fx:id="pageLabel" text="Page 1" textFill="WHITE"/>
                                <Button fx:id="nextButton" text="Next" onAction="#goToNextPage"
                                        style="-fx-background-color: #1e293b; -fx-text-fill: white; -fx-background-radius: 8; -fx-padding: 8 20;"/>
                            </children>
                        </HBox>

                    </children>
                </VBox>
            </content>
        </ScrollPane>
    </center>


</BorderPane>