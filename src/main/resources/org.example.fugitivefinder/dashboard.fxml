<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane prefHeight="900.0" prefWidth="1440.0" style="-fx-background-color: #081120;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.fugitivefinder.view.DashboardController">

    <left>
        <VBox prefWidth="220.0" spacing="18.0" style="-fx-background-color: #0f172a; -fx-padding: 20;">
            <children>
                <HBox spacing="10.0">
                    <children>
                        <ImageView fitHeight="48.0" fitWidth="48.0" preserveRatio="true">
                            <image>
                                <Image url="@images/logo.png" />
                            </image>
                        </ImageView>
                        <Label text="Fugitive Finder" textFill="WHITE" wrapText="true">
                            <font>
                                <Font size="16.0" />
                            </font>
                        </Label>
                    </children>
                </HBox>

                <Label style="-fx-background-color: #1e293b; -fx-text-fill: white; -fx-padding: 12 16; -fx-background-radius: 10;" text="Dashboard" />

                <Label onMouseClicked="#goToRewards" style="-fx-text-fill: #cbd5e1; -fx-padding: 12 16;" text="Rewards">
                    <cursor>
                        <Cursor fx:constant="HAND" />
                    </cursor>
                </Label>

                <Label onMouseClicked="#goToUserProfile" style="-fx-text-fill: #cbd5e1; -fx-padding: 12 16;" text="Profile">
                    <cursor>
                        <Cursor fx:constant="HAND" />
                    </cursor>
                </Label>
            </children>
        </VBox>
    </left>

    <top>
        <HBox alignment="CENTER_LEFT" spacing="14.0" style="-fx-background-color: #0b1320; -fx-padding: 18 24;">
            <children>
                <Label text="Dashboard" textFill="WHITE">
                    <font>
                        <Font size="30.0" />
                    </font>
                </Label>
                <Region HBox.hgrow="ALWAYS" />
                <Label fx:id="usernameLabel" text="DetectiveUser" textFill="WHITE">
                    <font>
                        <Font size="16.0" />
                    </font>
                </Label>
                <ImageView fitHeight="44.0" fitWidth="44.0" preserveRatio="true">
                    <image>
                        <Image url="@images/detective-avatar.png" />
                    </image>
                </ImageView>
            </children>
        </HBox>
    </top>

    <center>
        <VBox spacing="22.0" style="-fx-padding: 24;">
            <children>
                <Label text="Welcome back" textFill="WHITE">
                    <font>
                        <Font size="28.0" />
                    </font>
                </Label>

                <HBox spacing="18.0">
                    <children>
                        <AnchorPane prefHeight="120.0" prefWidth="260.0" style="-fx-background-color: #1e293b; -fx-background-radius: 16;">
                            <children>
                                <Label layoutX="20.0" layoutY="20.0" text="Total Most Wanted" textFill="#cbd5e1" />
                                <Label fx:id="totalWantedLabel" layoutX="20.0" layoutY="55.0" text="0" textFill="WHITE">
                                    <font>
                                        <Font size="34.0" />
                                    </font>
                                </Label>
                            </children>
                        </AnchorPane>

                        <AnchorPane prefHeight="120.0" prefWidth="260.0" style="-fx-background-color: #1e293b; -fx-background-radius: 16;">
                            <children>
                                <Label layoutX="20.0" layoutY="20.0" text="Reward Cases" textFill="#cbd5e1" />
                                <Label fx:id="rewardCasesLabel" layoutX="20.0" layoutY="55.0" text="0" textFill="WHITE">
                                    <font>
                                        <Font size="34.0" />
                                    </font>
                                </Label>
                            </children>
                        </AnchorPane>

                        <AnchorPane prefHeight="120.0" prefWidth="260.0" style="-fx-background-color: #1e293b; -fx-background-radius: 16;">
                            <children>
                                <Label layoutX="20.0" layoutY="20.0" text="Recent Updates" textFill="#cbd5e1" />
                                <Label fx:id="updatesLabel" layoutX="20.0" layoutY="55.0" text="0" textFill="WHITE">
                                    <font>
                                        <Font size="34.0" />
                                    </font>
                                </Label>
                            </children>
                        </AnchorPane>
                    </children>
                </HBox>

                <VBox spacing="14.0">
                    <children>
                        <HBox spacing="12.0" alignment="CENTER_LEFT" style="-fx-background-color: #1e293b; -fx-background-radius: 16; -fx-padding: 14;">
                            <children>
                                <ComboBox fx:id="crimeTypeComboBox" prefWidth="180.0" promptText="Crime Type" />
                                <ComboBox fx:id="sexComboBox" prefWidth="140.0" promptText="Sex" />
                                <TextField fx:id="cityField" prefWidth="180.0" promptText="City or Location" />

                                <VBox spacing="4.0">
                                    <children>
                                        <Label text="Min Age" textFill="WHITE" />
                                        <Slider fx:id="minAgeSlider" min="0.0" max="100.0" prefWidth="130.0" />
                                        <Label fx:id="minAgeLabel" text="0" textFill="#cbd5e1" />
                                    </children>
                                </VBox>

                                <VBox spacing="4.0">
                                    <children>
                                        <Label text="Max Age" textFill="WHITE" />
                                        <Slider fx:id="maxAgeSlider" min="0.0" max="100.0" prefWidth="130.0" value="100.0" />
                                        <Label fx:id="maxAgeLabel" text="100" textFill="#cbd5e1" />
                                    </children>
                                </VBox>

                                <CheckBox fx:id="rewardOnlyCheckBox" text="Reward Only" textFill="WHITE" />
                                <CheckBox fx:id="warningOnlyCheckBox" text="Warning Only" textFill="WHITE" />
                            </children>
                        </HBox>

                        <StackPane fx:id="mapContainer" prefHeight="521.0" prefWidth="1151.0"
                                   style="-fx-background-color: #1e293b; -fx-background-radius: 16;" />
                    </children>
                </VBox>

                <Label text="Featured Targets" textFill="WHITE">
                    <font>
                        <Font size="24.0" />
                    </font>
                </Label>

                <ScrollPane fitToWidth="true" prefHeight="520.0" style="-fx-background-color: transparent; -fx-background: transparent;">
                    <content>
                        <FlowPane fx:id="featuredCardsPane" hgap="18.0" prefWrapLength="1060.0" style="-fx-background-color: transparent;" vgap="18.0" />
                    </content>
                </ScrollPane>
            </children>
        </VBox>
    </center>
</BorderPane>
