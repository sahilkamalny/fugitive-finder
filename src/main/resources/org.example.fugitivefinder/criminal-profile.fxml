<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.Cursor?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="900.0" prefWidth="1440.0"
            xmlns="http://javafx.com/javafx/23.0.1"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.example.fugitivefinder.view.CriminalProfileController"
            style="-fx-background-color: #081120;">

    <left>
        <VBox prefWidth="220.0" spacing="18.0" style="-fx-background-color: #0f172a; -fx-padding: 20;">
            <children>
                <HBox spacing="10.0">
                    <children>
                        <ImageView fitHeight="48.0" fitWidth="48.0" preserveRatio="true">
                            <image>
                                <Image url="@images/logo.png" />
                            </image>
                        </ImageView>
                        <Label text="Fugitive Finder" textFill="WHITE" wrapText="true">
                            <font>
                                <Font size="16.0" />
                            </font>
                        </Label>
                    </children>
                </HBox>

                <Label text="Dashboard" onMouseClicked="#goToDashboard"
                       style="-fx-text-fill: #cbd5e1; -fx-padding: 12 16; -fx-cursor: hand;" />

                <Label text="Rewards" onMouseClicked="#goToRewards"
                       style="-fx-text-fill: #cbd5e1; -fx-padding: 12 16; -fx-cursor: hand;" />
                <Label text="Criminal Profile" style="-fx-background-color: #1e293b; -fx-text-fill: white; -fx-padding: 12 16; -fx-background-radius: 10;" />
            </children>
        </VBox>
    </left>

    <top>
        <HBox alignment="CENTER_LEFT" spacing="14.0" style="-fx-background-color: #0b1320; -fx-padding: 18 24;">
            <children>
                <Label text="Criminal Profile" textFill="WHITE">
                    <font>
                        <Font size="30.0" />
                    </font>
                </Label>
                <Region HBox.hgrow="ALWAYS" />
                <ImageView fitHeight="44.0" fitWidth="44.0" preserveRatio="true">
                    <image>
                        <Image url="@images/detective-avatar.png" />
                    </image>
                </ImageView>
            </children>
        </HBox>
    </top>

    <center>
        <VBox spacing="22.0" style="-fx-padding: 24;">
            <children>
                <HBox spacing="22.0" style="-fx-background-color: #111827; -fx-background-radius: 16; -fx-padding: 20;">
                    <children>
                        <ImageView fx:id="criminalImageView" fitHeight="320.0" fitWidth="270.0" preserveRatio="false" />

                        <VBox spacing="14.0">
                            <children>
                                <Label fx:id="nameLabel" text="Name" textFill="WHITE">
                                    <font>
                                        <Font size="32.0" />
                                    </font>
                                </Label>

                                <Label fx:id="aliasesLabel" text="ALIASES:" textFill="#e2e8f0">
                                    <font>
                                        <Font size="17.0" />
                                    </font>
                                </Label>

                                <Label fx:id="statusLabel" text="STATUS:" textFill="#e2e8f0">
                                    <font>
                                        <Font size="17.0" />
                                    </font>
                                </Label>

                                <Label fx:id="fieldOfficesLabel" text="FIELD OFFICES:" textFill="#e2e8f0">
                                    <font>
                                        <Font size="17.0" />
                                    </font>
                                </Label>

                                <HBox spacing="10.0">
                                    <children>
                                        <Label text="Reward" style="-fx-background-color: #1f2937; -fx-text-fill: white; -fx-padding: 8 12; -fx-background-radius: 8;" />
                                        <Label fx:id="rewardLabel" text="No Reward Listed"
                                               style="-fx-background-color: #f59e0b; -fx-text-fill: #111827; -fx-padding: 8 12; -fx-background-radius: 8; -fx-font-weight: bold;" />
                                    </children>
                                </HBox>

                                <Label fx:id="warningLabel" text="No warning provided." textFill="#fca5a5" wrapText="true">
                                    <font>
                                        <Font size="16.0" />
                                    </font>
                                </Label>

                                <Button mnemonicParsing="false" onAction="#saveTarget"
                                        prefHeight="42.0" prefWidth="180.0"
                                        style="-fx-background-color: #dc2626; -fx-text-fill: white; -fx-font-size: 16px; -fx-background-radius: 10;"
                                        text="Save Target">
                                    <cursor>
                                        <Cursor fx:constant="HAND" />
                                    </cursor>
                                </Button>
                            </children>
                        </VBox>
                    </children>
                </HBox>

                <VBox spacing="14.0" style="-fx-background-color: #111827; -fx-background-radius: 16; -fx-padding: 20;">
                    <children>
                        <Label text="Description" textFill="WHITE">
                            <font>
                                <Font size="22.0" />
                            </font>
                        </Label>
                        <Label fx:id="descriptionLabel" text="No description available." textFill="#cbd5e1" wrapText="true">
                            <font>
                                <Font size="16.0" />
                            </font>
                        </Label>
                    </children>
                </VBox>
            </children>
        </VBox>
    </center>
</BorderPane>